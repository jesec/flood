{
  "name": "flood",
  "version": "4.15.0",
  "description": "A modern Web UI for various torrent clients with multi-user and multi-client support",
  "keywords": [
    "typescript",
    "react",
    "node",
    "webui",
    "web ui",
    "rTorrent",
    "qBittorrent",
    "Transmission"
  ],
  "private": false,
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/jesec/flood.git"
  },
  "bugs": {
    "url": "https://github.com/jesec/flood/issues"
  },
  "files": [
    "dist",
    "node_modules",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "bin": {
    "flood": "dist/index.js"
  },
  "pkg": {
    "targets": [
      "node22-linuxstatic-x64",
      "node22-linuxstatic-arm64",
      "node22-macos-x64",
      "node22-macos-arm64",
      "node22-win-x64",
      "node22-win-arm64"
    ]
  },
  "scripts": {
    "build": "panda codegen && node scripts/build.mjs",
    "build-pkg": "rm -rf dist && npm run build && npm run pkg",
    "pkg": "pkg . --out-path dist-pkg --no-bytecode --public --options=enable-source-maps",
    "format-source": "prettier -w .",
    "check-source-formatting": "prettier -c .",
    "check-types": "tsc",
    "lint": "NODE_ENV=development eslint --max-warnings 0 .",
    "prepack": "rm -rf dist && npm run build",
    "start": "node --enable-source-maps --use_strict dist/index.js",
    "dev": "concurrently 'panda --watch' 'vite --config vite.config.ts' 'NODE_ENV=development vite-node -c vite.server.config.ts --watch server/bin/start.ts'",
    "start:development:client": "concurrently 'panda --watch' 'vite --config vite.config.ts'",
    "start:development:server": "NODE_ENV=development vite-node -c vite.server.config.ts --watch server/bin/start.ts",
    "start:test:rtorrent": "node scripts/testsetup.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook"
  },
  "devDependencies": {
    "@babel/core": "^8.0.0",
    "@babel/eslint-parser": "^8.0.0",
    "@babel/preset-env": "^8.0.0",
    "@babel/preset-react": "^8.0.0",
    "@babel/preset-typescript": "^8.0.0",
