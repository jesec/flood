{
  "name": "flood",
  "version": "4.13.8",
  "description": "A modern Web UI for various torrent clients with multi-user and multi-client support",
  "keywords": [
    "typescript",
    "react",
    "node",
    "webui",
    "web ui",
    "rTorrent",
    "qBittorrent",
    "Transmission"
  ],
  "private": false,
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/jesec/flood.git"
  },
  "bugs": {
    "url": "https://github.com/jesec/flood/issues"
  },
  "files": [
    "dist",
    "node_modules",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "bin": {
    "flood": "dist/index.js"
  },
  "pkg": {
    "targets": [
      "node22-linuxstatic-x64",
      "node22-linuxstatic-arm64",
      "node22-macos-x64",
      "node22-macos-arm64",
      "node22-win-x64",
      "node22-win-arm64"
    ]
  },
  "scripts": {
    "build": "panda codegen --cwd client && node scripts/build.mjs",
    "build-pkg": "rm -rf dist && npm run build && npm run pkg",
    "pkg": "pkg . --out-path dist-pkg --no-bytecode --public --options=enable-source-maps",
    "format-source": "prettier -w .",
    "check-source-formatting": "prettier -c .",
    "check-types": "tsc",
    "lint": "NODE_ENV=development eslint --max-warnings 0 .",
    "prepack": "rm -rf dist && npm run build",
    "start": "node --enable-source-maps --use_strict dist/index.js",
    "start:development:client": "concurrently \"panda --cwd client --watch\" \"node client/scripts/development.mjs\"",
    "start:development:server": "NODE_ENV=development tsx watch server/bin/start.ts",
    "start:test:rtorrent": "node scripts/testsetup.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006 --config-dir client/.storybook",
    "build-storybook": "storybook build --config-dir client/.storybook",
    "test-storybook": "test-storybook"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/js": "^9.39.4",
    "@types/fs-extra": "^9.0.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^2.1.9",
    "chalk": "^4.1.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^9.1.20",
    "fs-extra": "^10.1.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^2.8.8",
    "tsx": "^4.21.0",
    "typescript": "~5.0.4",
    "typescript-eslint": "^8.58.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "browserslist": [
    "> 2%",
    "last 10 chrome version",
    "last 5 firefox version",
    "last 5 edge version",
    "last 2 iOS version",
    "last 2 Safari version"
  ],
  "lint-staged": {
    "*": "prettier --ignore-unknown -w"
  },
  "packageManager": "pnpm@9.7.0"
}
